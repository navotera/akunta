{
    "name": "akunta/ecopa-client",
    "description": "Ecopa (Main Tier) SSO + API client. OIDC-style authorization-code flow, JWKS verify, app catalog access.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^6.10 || ^7.0",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.5",
        "pestphp/pest": "^3.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Akunta\\EcopaClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Akunta\\EcopaClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Akunta\\EcopaClient\\EcopaClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
