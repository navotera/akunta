APP_NAME=Akunta
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Mode toggles (per spec §2.2, §3.3)
APP_MODE=self_hosted
USE_MAIN_TIER=false

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (default = control; tenant DB resolved per request) ---
DB_CONNECTION=ecosystem_control
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ecosystem_control
DB_USERNAME=postgres
DB_PASSWORD=

# --- Control DB (shared master per spec §11, arch §4.3) ---
CONTROL_DB_HOST=127.0.0.1
CONTROL_DB_PORT=5432
CONTROL_DB_DATABASE=ecosystem_control
CONTROL_DB_USERNAME=postgres
CONTROL_DB_PASSWORD=

# --- Tenant DB (template; database name swapped by TenantResolver) ---
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=postgres
TENANT_DB_PASSWORD=
TENANT_DB_PREFIX=tenant_

# --- Tenancy resolution ---
TENANT_HEADER=X-Tenant-Slug
TENANT_SUBDOMAIN_ENABLED=true
TENANT_BASE_DOMAIN=localhost
TENANT_JWT_CLAIM=tenant_id

# --- Cross-app entity sync (step 13, spec §8.3) ---
# Set leading-dot domain so akunta_entity cookie propagates across sibling panels.
# Empty = same-origin only (safe dev default).
ECOSYSTEM_BASE_DOMAIN=

# --- Session / cache / queue (Redis per spec §4.7.B-C) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=akunta

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@akunta.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Ecopa (Main Tier SSO) ---
# Register this app in Ecopa admin → Apps Management → SSO Integrations
# to obtain client_id + client_secret. Set redirect_uri exactly to:
#   {APP_URL}/auth/ecopa/callback
ECOPA_URL=https://home.opensynergic.com
ECOPA_CLIENT_ID=
ECOPA_CLIENT_SECRET=
ECOPA_REDIRECT_URI="${APP_URL}/auth/ecopa/callback"
ECOPA_API_TOKEN=
ECOPA_EXPECTED_ISSUER=ecopa
ECOPA_JWKS_CACHE_SECONDS=3600
ECOPA_HTTP_TIMEOUT=8

# Webhook secret — copy from Ecopa Apps Management after first metadata sync.
ECOPA_WEBHOOK_SECRET=

# Auto-register users on first SSO login (default: false — admin must pre-create user)
AUTH_SSO_AUTO_REGISTER=false

# --- Demo Mode ---
# Set true → DatabaseSeeder also runs DemoDataSeeder which provisions a fully
# populated "PT. Demo" entity (CoA + branches + cost centers + projects +
# partners + ~40 posted journals + sample journal templates + recurring journal).
# Idempotent. Skip in CI / production.
SEED_DEMO_DATA=false
